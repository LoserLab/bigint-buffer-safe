{
  "name": "bigint-buffer-safe",
  "version": "1.0.0",
  "description": "Safe, pure-JS drop-in replacement for bigint-buffer. Fixes CVE-2025-3194 (buffer overflow / DoS). No native bindings, no vulnerabilities.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bigint",
    "buffer",
    "bigint-buffer",
    "solana",
    "CVE-2025-3194",
    "security",
    "drop-in-replacement"
  ],
  "author": "heathen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loserlab/bigint-buffer-safe"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
